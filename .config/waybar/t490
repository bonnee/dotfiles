{
    "layer": "bottom",
    "position": "bottom",
    "modules-left": ["sway/workspaces","sway/mode","sway/window"],
    "modules-center": [],
    "modules-right": ["tray","idle_inhibitor","group/audio","cpu","temperature","custom/fan","load","memory","group/power","clock"],
    "sway/window": {
        "max-length": 192
    },
    "sway/workspaces": {
      "smooth-scrolling-threshold": 6
    },
    "group/power": {
      "orientation": "horizontal",
      "drawer": {
	"click-to-reveal": true,
	"transition-duration": 200,
	"transition-left-to-right": true,
      },
      "modules": [
	"battery",
	"battery#power",
	"power-profiles-daemon",
      ],
    },
    "battery": {
	"interval": 10,
        "format": "{icon} {capacity}%",
        //"format-icons": ["¾░éÄ","¾░ü║","¾░ü╗","¾░ü╝","¾░ü¢","¾░ü¥","¾░ü┐","¾░éÇ","¾░éü","¾░éé","¾░ü╣"],
        "format-icons": ["&#xf244;","&#xf243;","&#xf242;","&#xf241;","&#xf240;"],
	"format-plugged": "´çª {capacity}%",
	"format-charging": "¾░éä {capacity}%",
	"tooltip-format": "Cycles:\t{cycles}\nSoH:\t{health}%",
	"states": {
	    "low": 40,
	    "warning": 25,
	    "critical": 10
	},
    },
    "battery#power": {
      "format": "&#xf06d; {power:0.1f}W",
      "interval": 5
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "´âº",
        "performance": "´âº",
        "balanced": "´ëÄ",
        "power-saver": "´ü¼"
      }
    },
    "clock": {
        "format":"´ü│ {:%a %d, %H:%M (%Z)}",
	"tooltip-format": "<tt><small>{calendar}</small></tt>",
	"smooth-scrolling-threshold": 6,
	"timezones": [
	  "Europe/Rome",
	  "America/Detroit",
	],
        "calendar": {
          "mode"          : "year",
          "mode-mon-col"  : 3,
          "weeks-pos"     : "",
          "on-scroll"     : 1,
          "on-click-right": "mode",
          "format": {
            "months":     "<span color='#ffead3'><b>{}</b></span>",
            "days":       "<span color='#ecc6d9'><b>{}</b></span>",
            "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
            "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
            "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
          },
        "actions":  {
	  "on-click": "tz_up",
          "on-click-right": "mode",
          "on-scroll-up": "shift_up",
          "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
	"format": "&#xf4bc; {icon0} {icon1} {icon2} {icon3} {icon4} {icon5} {icon6} {icon7}",
	"format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"],
	"states": {
	    "high": 40,
	    "max": 95
	}
    },
    "load": {
      "format": "&#xF029A; {load1}",
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "´ü«",
        "deactivated": "´ü░"
      }
    },
    "memory": {
      "interval": 20,
      "format": "´ö© {}%",
      "tooltip-format": "Mem:\t{used:0.1f}G / {total:0.1f}G\nSwap:\t{swapUsed:0.1f}G / {swapTotal:0.1f}G",
    },
    "wireplumber#icon": {
      "format": "<span size='large'>{icon}</span>",
      "format-bluetooth": "{icon}¾░é» {volume}%",
      "format-muted": "<span size='large'>¾░Øƒ</span>",
      "format-icons": {
          "headphone": "¾░ïï",
          "hands-free": "¾░ïÄ",
          "headset": "¾░ïÄ",
          "phone": "´éò",
          "phone-muted": "´ÅØ",
          "portable": "´éò",
          "car": "´å╣",
          "default": ["&#xf027;", "&#xf6a8;", "&#xf028;"],
      },
      "scroll-step": 2,
      "smooth-scrolling-threshold": 1
    },
    "wireplumber#sink": {
      "format": "{volume}%",
      "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
      "on-click": "pavucontrol",
      "smooth-scrolling-threshold": 1
    },
    "wireplumber#source": {
      "node-type": "Audio/Source",
      "format": "<span size='large'>¾░ì¼</span> {volume}%",
      "format-muted": "¾░ì¡",
      "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
      "on-click": "pavucontrol",
      "scroll-step": 2,
      "smooth-scrolling-threshold": 1
    },
    "pulseaudio": {
	"format": "{icon} {volume}%",
        "format-bluetooth": "{icon}¾░é» {volume}%",
	"format-muted": "¾░Øƒ",
	"format-icons": {
    	    "headphone": "¾░ïï",
    	    "hands-free": "¾░ïÄ",
    	    "headset": "¾░ïÄ",
    	    "phone": "´éò",
	    "phone-muted": "´ÅØ",
    	    "portable": "´éò",
    	    "car": "´å╣",
	    "default": ["&#xf027;", "&#xf6a8;", "&#xf028;"],
	},
	"scroll-step": 2,
	"smooth-scrolling-threshold": 2
    },
    "group/audio": {
      "orientation": "horizontal",
      "drawer": {
	"click-to-reveal": true,
	"transition-duration": 200,
	"transition-left-to-right": true,
      },
      "modules": [
	"wireplumber#icon",
	"wireplumber#sink",
	"wireplumber#source",
      ],
    },
    "temperature": {
      "thermal-zone": 7,
      "warning-threshold": 55,
      "critical-threshold": 75,
      "format-critical": "´ïç {temperatureC}┬░C",
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["´ïï","´ïè","´ïë","´ïê","´ïç"]
    },
    "custom/fan": {
      "format": "{}",
      "interval": 10,
      "exec": "$HOME/.config/waybar/scripts/fan.sh"
    },
     "tray": {
	"icon-size": 24,
	"spacing": 8,
    },
    "custom/speed": {
      "format": "{} km/h",
      "interval": 10,
      "exec": "$HOME/.config/waybar/scripts/ciufciuf.sh"
    }
}

