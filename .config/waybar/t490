{
    "layer": "bottom",
    "position": "bottom",
    "modules-left": ["sway/workspaces","sway/mode","sway/window"],
    "modules-center": [],
    "modules-right": ["tray","idle_inhibitor","pulseaudio","cpu","temperature","custom/fan","load","memory","group/power","clock"],
    "sway/window": {
        "max-length": 192
    },
    "sway/workspaces": {
      "smooth-scrolling-threshold": 6
    },
    "group/power": {
      "orientation": "horizontal",
      "drawer": {
	"click-to-reveal": true,
	"transition-duration": 500,
	"transition-left-to-right": false,
      },
      "modules": [
	"battery",
	"battery#power",
	"power-profiles-daemon",
      ],
    },
    "battery": {
	"interval": 10,
        "format": "{icon} {capacity}%",
        "format-icons": ["у°‚Ћ","у°Ѓє","у°Ѓ»","у°Ѓј","у°ЃЅ","у°Ѓѕ","у°Ѓї","у°‚Ђ","у°‚Ѓ","у°‚‚","у°Ѓ№"],
	"format-plugged": "п‡¦ {capacity}%",
	"format-charging": "у°‚„ {capacity}%",
	"tooltip-format": "Cycles:\t{cycles}\nSoH:\t{health}%",
	"states": {
	    "low": 40,
	    "warning": 25,
	    "critical": 10
	},
    },
    "battery#power": {
      "format": "&#xf06d; {power:0.1f}W",
      "interval": 5
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "пѓ§",
        "performance": "пѓ§",
        "balanced": "п‰Ћ",
        "power-saver": "пЃ¬"
      }
    },
    "clock": {
        "format":"пЃі {:%a %d, %H:%M (%Z)}",
	"tooltip-format": "<tt><small>{calendar}</small></tt>",
	"smooth-scrolling-threshold": 6,
	"timezones": [
	  "Europe/Rome",
	  "America/Detroit",
	],
        "calendar": {
          "mode"          : "year",
          "mode-mon-col"  : 3,
          "weeks-pos"     : "",
          "on-scroll"     : 1,
          "on-click-right": "mode",
          "format": {
            "months":     "<span color='#ffead3'><b>{}</b></span>",
            "days":       "<span color='#ecc6d9'><b>{}</b></span>",
            "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
            "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
            "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
          },
        "actions":  {
	  "on-click": "tz_up",
          "on-click-right": "mode",
          "on-scroll-up": "shift_up",
          "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
	"format": "&#xf4bc; {icon0} {icon1} {icon2} {icon3} {icon4} {icon5} {icon6} {icon7}",
	"format-icons": ["в–Ѓ", "в–‚", "в–ѓ", "в–„", "в–…", "в–†", "в–‡", "в–€"],
	"states": {
	    "high": 40,
	    "max": 95
	}
    },
    "load": {
      "format": "&#xF029A; {load1}",
    },
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated": "пЃ®",
        "deactivated": "пЃ°"
      }
    },
    "memory": {
      "interval": 20,
      "format": "п”ё {}%",
      "tooltip-format": "Mem:\t{used:0.1f}G / {total:0.1f}G\nSwap:\t{swapUsed:0.1f}G / {swapTotal:0.1f}G",
    },
    "pulseaudio": {
	"format": "{icon} {volume}%",
        "format-bluetooth": "{icon}у°‚Ї {volume}%",
	"format-muted": "у°ќџ",
	"format-icons": {
    	    "headphone": "у°‹‹",
    	    "hands-free": "у°‹Ћ",
    	    "headset": "у°‹Ћ",
    	    "phone": "п‚•",
	    "phone-muted": "пЏќ",
    	    "portable": "п‚•",
    	    "car": "п†№",
	    "default": ["&#xf027;", "&#xf6a8;", "&#xf028;"],
	},
	"scroll-step": 2,
	"smooth-scrolling-threshold": 2
    },
    "temperature": {
      "thermal-zone": 7,
      "critical-threshold": 75,
      "format-critical": "п‹‡ {temperatureC}В°C",
      "format": "{icon} {temperatureC}В°C",
      "format-icons": ["п‹‹","п‹Љ","п‹‰","п‹€","п‹‡"]
    },
    "custom/fan": {
      "format": "{}",
      "interval": 10,
      "exec": "$HOME/.config/waybar/scripts/fan.sh"
    },
     "tray": {
	"icon-size": 24,
    },
    "custom/speed": {
      "format": "{} km/h",
      "interval": 10,
      "exec": "$HOME/.config/waybar/scripts/ciufciuf.sh"
    }
}

