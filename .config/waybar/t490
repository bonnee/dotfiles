{
    "layer": "bottom",
    "position": "bottom",
    "modules-left": ["sway/workspaces","sway/mode","sway/window"],
    "modules-center": [],
    "modules-right": ["tray","idle_inhibitor","pulseaudio","cpu","load","memory","custom/fan","temperature","group/power","clock"],
    "sway/window": {
        "max-length": 192
    },
    "sway/workspaces": {
      "smooth-scrolling-threshold": 6
    },
    "group/power": {
      "orientation": "horizontal",
      "drawer": {
	"transition-duration": 500,
	"transition-left-to-right": false,
      },
      "modules": [
	"battery",
	"custom/tlp",
	"battery#power",
      ],
    },
    "battery": {
	"interval": 10,
        "format": "{icon} {capacity}%",
        "format-icons": ["¾░éÄ","¾░ü║","¾░ü╗","¾░ü╝","¾░ü¢","¾░ü¥","¾░ü┐","¾░éÇ","¾░éü","¾░éé","¾░ü╣"],
	"format-plugged": "´çª {capacity}%",
	"format-charging": "¾░éä {capacity}%",
	"tooltip-format": "Cycles:\t{cycles}\nSoH:\t{health}%",
	"states": {
	    "low": 40,
	    "warning": 25,
	    "critical": 10
	},
	"on-click": "threshy-gui"
    },
    "battery#power": {
      "format": "&#xf0e7; {power:0.1f}W",
      "interval": 5
    },
    "custom/tlp": {
      "format": "{}",
      "interval": 20,
      "exec": "$HOME/.config/waybar/scripts/tlp",
      "exec-on-event": true,
      "on-click": "$HOME/.config/waybar/scripts/tlp click",
      "signal": 8
    },
    "custom/consumption": {
      "format": "&#xf0e7; {}",
      "interval": 5,
      "exec": "$HOME/.config/waybar/scripts/consumption"
    },
    "clock": {
        "format":"´ü│ {:%a %d, %H:%M (%Z)}",
	"tooltip-format": "<tt><small>{calendar}</small></tt>",
	"smooth-scrolling-threshold": 6,
	"timezones": [
	  "Europe/Rome",
	  "America/Detroit",
	],
        "calendar": {
          "mode"          : "year",
          "mode-mon-col"  : 3,
          "weeks-pos"     : "",
          "on-scroll"     : 1,
          "on-click-right": "mode",
          "format": {
            "months":     "<span color='#ffead3'><b>{}</b></span>",
            "days":       "<span color='#ecc6d9'><b>{}</b></span>",
            "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
            "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
            "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
          },
        "actions":  {
	  "on-click": "tz_up",
          "on-click-right": "mode",
          "on-scroll-up": "shift_up",
          "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
	"format": "&#xf4bc; {icon0} {icon1} {icon2} {icon3} {icon4} {icon5} {icon6} {icon7}",
	"format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"],
	"states": {
	    "high": 40,
	    "max": 95
	}
    },
    "load": {
      "format": "&#xF029A; {load1}",
    },
    "memory": {
	"interval": 20,
	"format": "&#xF538; {}%",
	"tooltip-format": "Mem:\t{used:0.1f}G / {total:0.1f}G\nSwap:\t{swapUsed:0.1f}G / {swapTotal:0.1f}G",
    },
    "pulseaudio": {
	"format": "{icon} {volume}%",
        "format-bluetooth": "{icon}¾░é» {volume}%",
	"format-muted": "¾░Øƒ",
	"format-icons": {
    	    "headphone": "¾░ïï",
    	    "hands-free": "¾░ïÄ",
    	    "headset": "¾░ïÄ",
    	    "phone": "´éò",
    	    "portable": "´éò",
    	    "car": "´å╣",
	"smooth-scrolling-threshold": 2
    },
    "temperature": {
      "thermal-zone": 7,
      "critical-threshold": 75,
      "format-critical": "´ïç {temperatureC}┬░C",
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["´ïï","´ïè","´ïë","´ïê","´ïç"]
    },
     "tray": {
	"icon-size": 32,
	"spacing": 16
    },
    "idle_inhibitor": {
	"format": "{icon}",
        "format-icons": {
	  "activated": "´ü«",
	  "deactivated": "´ü░"
        }
    },
    "custom/fan": {
      "format": "{}",
      "interval": 10,
      "exec": "$HOME/.config/waybar/scripts/fan"
    },
    "custom/updates": {
      "format": "{} &#xf2f1;",
      "signal": 12,
      "exec": "$HOME/.config/waybar/scripts/updates"
    },
    "custom/speed": {
      "format": "{} km/h",
      "interval": 10,
      "exec": "$HOME/.config/waybar/scripts/ciufciuf.sh"
    }
}
}
